<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header with Back Button and Username -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBackFromUserProfile"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="#A67B5B"
                    android:contentDescription="Back" />

                <TextView
                    android:id="@+id/tvUserProfileHeaderName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Pata"
                    android:textSize="24sp"
                    android:textColor="#A67B5B"
                    android:fontFamily="@font/font" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp" />

            <!-- User Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <!-- Full Name -->
                <TextView
                    android:id="@+id/tvUserProfileFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Davide Ronchini"
                    android:textSize="28sp"
                    android:textColor="#A67B5B"
                    android:fontFamily="@font/font"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivUserProfileAvatar"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_add_puppy_placeholder"
                        app:shapeAppearanceOverlay="@style/RoundedSquare" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <!-- Account Type -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/home_ic_home"
                                app:tint="#A67B5B"
                                android:contentDescription="Type" />
                            <TextView
                                android:id="@+id/tvUserProfileAccountType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Private"
                                android:textSize="16sp"
                                android:textColor="#8E8E8E"
                                android:fontFamily="@font/font" />
                        </LinearLayout>

                        <!-- Location -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_location"
                                app:tint="#A67B5B"
                                android:contentDescription="Location" />
                            <TextView
                                android:id="@+id/tvUserProfileLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Ortona (CH)"
                                android:textSize="16sp"
                                android:textColor="#4A3B32"
                                android:fontFamily="@font/font" />
                        </LinearLayout>

                        <!-- Actions -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/btnCallUserProfile"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_search_bar"
                                android:paddingHorizontal="16dp"
                                android:gravity="center_vertical"
                                android:clickable="true"
                                android:focusable="true">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/sign_ic_phone"
                                    app:tint="#8E8E8E"
                                    android:contentDescription="Call" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Call"
                                    android:textSize="14sp"
                                    android:textColor="#8E8E8E" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnShareUserProfile"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/bg_search_bar"
                                android:paddingHorizontal="16dp"
                                android:gravity="center_vertical"
                                android:clickable="true"
                                android:focusable="true">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_share"
                                    app:tint="#8E8E8E"
                                    android:contentDescription="Share" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Share profile"
                                    android:textSize="14sp"
                                    android:textColor="#8E8E8E" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Post:"
                    android:textSize="18sp"
                    android:textColor="#4A3B32"
                    android:fontFamily="@font/font" />
                <ImageView
                    android:id="@+id/ivFilterUserProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_filter"
                    app:tint="#4A3B32"
                    android:contentDescription="Filter Posts" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUserProfilePosts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>