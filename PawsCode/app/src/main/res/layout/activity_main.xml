<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="48dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/logo_Xa"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_paws"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        android:scaleType="fitCenter"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tabSignIn_Xa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN IN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3B32"
                android:paddingBottom="4dp" />

            <View
                android:id="@+id/lineSignIn_Xa"
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:background="#F09B42" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tabSignUp_Xa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN UP"
                android:textSize="14sp"
                android:textColor="#4A3B32"
                android:paddingBottom="4dp" />

            <View
                android:id="@+id/lineSignUp_Xa"
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:background="#00000000" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/username_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_xa"
        android:hint="Username"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_user_xa"
        android:drawablePadding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/password_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_xa"
        android:hint="Password"
        android:inputType="textPassword"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_lock_xa"
        android:drawablePadding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLogin_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_button_xa"
        app:backgroundTint="@null"
        android:text="SIGN IN"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/forgotPassword_Xa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textSize="12sp"
        android:textColor="#A0A0A0" />

</LinearLayout>