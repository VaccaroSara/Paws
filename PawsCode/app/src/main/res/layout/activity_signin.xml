<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="48dp"
    android:paddingEnd="48dp"
    android:paddingTop="120dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo_Xa"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:src="@drawable/sign_ic_logo"
        android:layout_marginBottom="40dp"
        android:scaleType="fitCenter"
        android:transitionName="logo_transition"/>

    <!-- Menu SIGN IN / SIGN UP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tabSignIn_Xa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN IN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3B32"
                android:paddingBottom="4dp"
                android:transitionName="tab_signin_transition" />

            <View
                android:id="@+id/lineSignIn_Xa"
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:background="#F09B42"
                android:transitionName="line_signin_transition" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tabSignUp_Xa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN UP"
                android:textSize="14sp"
                android:textColor="#4A3B32"
                android:paddingBottom="4dp"
                android:transitionName="tab_signup_transition" />

            <View
                android:id="@+id/lineSignUp_Xa"
                android:layout_width="50dp"
                android:layout_height="3dp"
                android:background="#00000000"
                android:transitionName="line_signup_transition" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/username_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/sign_bg_input"
        android:hint="Username"
        android:textSize="14sp"
        android:drawableStart="@drawable/sign_ic_user"
        android:drawablePadding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="12dp"
        android:transitionName="username_transition" />

    <EditText
        android:id="@+id/password_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/sign_bg_input"
        android:hint="Password"
        android:inputType="textPassword"
        android:textSize="14sp"
        android:drawableStart="@drawable/sign_ic_lock"
        android:drawablePadding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="24dp"
        android:transitionName="password_transition" />

    <!-- Bottone -->
    <Button
        android:id="@+id/btnLogin_Xa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/sign_bg_button"
        app:backgroundTint="@null"
        android:text="SIGN IN"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:transitionName="button_transition" />

    <!-- Testo Dimenticato -->
    <TextView
        android:id="@+id/forgotPassword_Xa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textSize="12sp"
        android:textColor="#A0A0A0" />

</LinearLayout>