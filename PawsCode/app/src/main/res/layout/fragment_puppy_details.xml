<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EAE3D9">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top Section: Image and Name/Tags -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/ivDetailPuppyImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_add_puppy_placeholder" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvDetailPuppyName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Romeo"
                        android:textSize="32sp"
                        android:textColor="#4A3B32"
                        android:fontFamily="serif" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <FrameLayout
                            android:id="@+id/containerGender"
                            android:layout_width="32dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_gender_circle">
                            <ImageView
                                android:id="@+id/ivDetailGenderIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_male" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvDetailType"
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_white_circle"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="Dog"
                            android:textColor="#4A3B32"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvDetailAge"
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_white_circle"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="1 years"
                            android:textColor="#4A3B32"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D1C7B7"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- Owner Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sign_ic_user"
                        app:tint="#4A3B32" />
                    <TextView
                        android:id="@+id/tvOwnerUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="sarettavacc27"
                        android:textColor="#4A3B32"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sign_ic_phone"
                        app:tint="#4A3B32" />
                    <TextView
                        android:id="@+id/tvOwnerPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="+39 626 444 3333"
                        android:textColor="#4A3B32"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_location"
                        app:tint="#4A3B32" />
                    <TextView
                        android:id="@+id/tvOwnerLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Ortona (CH)"
                        android:textColor="#4A3B32"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPuppyCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Meet Romeo! An adorable tri-color puppy with captivating brown eyes..."
                    android:textColor="#4A3B32"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btnBackFromDetails"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_white_circle"
                android:padding="12dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#4A3B32" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>