<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Paws" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- 1. Diciamo ad Android di fare la barra di stato BIANCA -->
        <item name="android:statusBarColor">#FFFFFF</item>

        <!-- 2. Diciamo ad Android che, essendo lo sfondo bianco,
             l'ora e le icone della batteria devono diventare SCURE,
             altrimenti non le leggeresti! -->
        <item name="android:windowLightStatusBar">true</item>

    </style>

    <style name="Theme.Paws" parent="Base.Theme.Paws" />

    <!-- Splash Screen Theme (Hiding system logo) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/transparent_icon</item>
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="postSplashScreenTheme">@style/Theme.Paws</item>
    </style>

    <style name="CustomSpinnerPopup" parent="Widget.AppCompat.ListPopupWindow">
        <item name="android:popupBackground">#F0F0F0</item>
        <item name="android:divider">#D3D3D3</item>
        <item name="android:dividerHeight">1dp</item>
        <item name="android:dropDownVerticalOffset">4dp</item>
    </style>
    <style name="RoundedSquare">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>